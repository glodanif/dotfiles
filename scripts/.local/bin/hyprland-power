#!/bin/zsh
case "$1" in
  logout)   CMD="hyprctl dispatch exit" ; MSG="Logging out..." ;;
  reboot)   CMD="loginctl reboot"       ; MSG="Rebooting..." ;;
  shutdown) CMD="loginctl poweroff"     ; MSG="Shutting down..." ;;
  *)
    echo "Usage: hyprland-power [logout|reboot|shutdown]"
    exit 1
    ;;
esac

notify-send -t 3000 "$MSG"
nohup zsh -c "sleep 2 && $CMD" >/dev/null 2>&1 &
hypr-close-all-windows
sleep 1

