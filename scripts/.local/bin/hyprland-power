#!/bin/zsh
case "$1" in
  logout)   CMD="hyprctl dispatch exit" ; MSG="Logging out..." ;;
  reboot)   CMD="loginctl reboot"       ; MSG="Rebooting..." ;;
  shutdown) CMD="loginctl poweroff"     ; MSG="Shutting down..." ;;
  reboot-windows)
    sudo -v || exit 1
    CMD="{ sudo efibootmgr --bootnext 0000 && sudo reboot; }"
    MSG="Rebooting to Windows..."
    ;;
  *)
    echo "Usage: hyprland-power [logout|reboot|shutdown|reboot-windows]"
    exit 1
    ;;
esac

python "$HOME/.config/wlogout/overlay.py" "$MSG" &
nohup zsh -c "sleep 2 && $CMD" >/dev/null 2>&1 &
hypr-close-all-windows
sleep 1

