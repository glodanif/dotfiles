#!/bin/zsh
# sys-update — update Arch system packages and AUR

set -e

source "$HOME/.config/bash/utils.sh"

keep_screen_on

section "System Update"
sudo -v

section "Syncing keyrings..."
sudo pacman -Sy --noconfirm archlinux-keyring >/dev/null

section "Updating system packages..."
sudo pacman -Syyu --noconfirm

if command -v yay &>/dev/null && pacman -Qem &>/dev/null; then
  section "Updating AUR packages..."
  yay -Sua --noconfirm --cleanafter
fi

orphans=$(pacman -Qtdq 2>/dev/null || true)
if [[ -n $orphans ]]; then
  section "Removing orphans..."
  sudo pacman -Rs --noconfirm $orphans
fi

section "Done."
notify-send -t 2000 "Update complete."

if [[ ! -d /usr/lib/modules/$(uname -r) ]]; then
  section "Kernel updated — reboot when ready." "\e[33m"
fi

rm -f /tmp/waybar-updates-cache
pkill -RTMIN+8 waybar

