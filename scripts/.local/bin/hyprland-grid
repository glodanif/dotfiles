#!/bin/zsh

set -euo pipefail

MONITOR="${1:-}"
GRID="${2:-}"
STATE_FILE="/tmp/hypr-grid-${MONITOR}.lock"

usage() {
    echo "Usage: $0 <monitor> <grid>"
    echo "  monitor: e.g. DP-1"
    echo "  grid:    1x3 | 1x2 | 2x2 | 3x3 (ROWSxCOLS)"
    exit 1
}

[[ -z "$MONITOR" || -z "$GRID" ]] && usage

# Parse grid
ROWS=$(echo "$GRID" | cut -dx -f1)
COLS=$(echo "$GRID" | cut -dx -f2)
REQUIRED=$(( ROWS * COLS ))

if ! [[ "$ROWS" =~ ^[0-9]+$ && "$COLS" =~ ^[0-9]+$ ]]; then
    notify-send "hypr-grid" "Invalid grid format: $GRID"
    exit 1
fi

# Toggle off
if [[ -f "$STATE_FILE" ]]; then
    hyprctl reload
    rm -f "$STATE_FILE"
    exit 0
fi

# Get monitor info
MONITOR_JSON=$(hyprctl monitors -j | jq --arg m "$MONITOR" '.[] | select(.name == $m)')

if [[ -z "$MONITOR_JSON" ]]; then
    notify-send "hypr-grid" "Monitor not found: $MONITOR"
    exit 1
fi

MONITOR_ID=$(echo "$MONITOR_JSON" | jq -r '.id')
WORKSPACE_ID=$(echo "$MONITOR_JSON" | jq -r '.activeWorkspace.id')
MON_X=$(echo "$MONITOR_JSON" | jq -r '.x')
MON_Y=$(echo "$MONITOR_JSON" | jq -r '.y')
MON_W=$(echo "$MONITOR_JSON" | jq -r '.width')
MON_H=$(echo "$MONITOR_JSON" | jq -r '.height')
SCALE=$(echo "$MONITOR_JSON" | jq -r '.scale')

# Convert to logical pixels (handle scale using awk for float division)
LOG_W=$(awk "BEGIN {printf \"%d\", $MON_W / $SCALE}")
LOG_H=$(awk "BEGIN {printf \"%d\", $MON_H / $SCALE}")
LOG_X=$MON_X
LOG_Y=$MON_Y

# Get windows on this workspace + monitor only
WINDOWS=$(hyprctl clients -j | jq --argjson ws "$WORKSPACE_ID" --argjson mon "$MONITOR_ID" \
    '[.[] | select(.workspace.id == $ws and .monitor == $mon)]')

WIN_COUNT=$(echo "$WINDOWS" | jq 'length')

# Debug logging
echo "Monitor: $MONITOR (ID: $MONITOR_ID)" > /tmp/hypr-grid-debug.log
echo "Workspace: $WORKSPACE_ID" >> /tmp/hypr-grid-debug.log
echo "Monitor position: ${MON_X},${MON_Y} ${MON_W}x${MON_H}" >> /tmp/hypr-grid-debug.log
echo "Logical size: ${LOG_W}x${LOG_H}" >> /tmp/hypr-grid-debug.log
echo "Found $WIN_COUNT windows (need $REQUIRED)" >> /tmp/hypr-grid-debug.log
echo "$WINDOWS" | jq -r '.[] | "  - \(.class) at \(.at)"' >> /tmp/hypr-grid-debug.log

if [[ "$WIN_COUNT" -ne "$REQUIRED" ]]; then
    notify-send "hypr-grid" "Expected $REQUIRED windows for ${GRID}, found ${WIN_COUNT}"
    exit 1
fi

# Save state marker
touch "$STATE_FILE"

# Hide Waybar
pkill -SIGUSR1 waybar 2>/dev/null || true

# Kill gaps, borders, rounding
hyprctl keyword general:gaps_in 0
hyprctl keyword general:gaps_out 0
hyprctl keyword general:border_size 0
hyprctl keyword decoration:rounding 0

# Cell dimensions
CELL_W=$(( LOG_W / COLS ))
CELL_H=$(( LOG_H / ROWS ))

# Position each window
for i in $(seq 0 $(( WIN_COUNT - 1 ))); do
    ADDR=$(echo "$WINDOWS" | jq -r --argjson i "$i" '.[$i].address')

    ROW=$(( i / COLS ))
    COL=$(( i % COLS ))

    WIN_X=$(( LOG_X + COL * CELL_W ))
    WIN_Y=$(( LOG_Y + ROW * CELL_H ))

    # Last col/row absorbs rounding remainder
    if [[ $(( COL + 1 )) -eq "$COLS" ]]; then
        WIN_W=$(( LOG_W - COL * CELL_W ))
    else
        WIN_W=$CELL_W
    fi

    if [[ $(( ROW + 1 )) -eq "$ROWS" ]]; then
        WIN_H=$(( LOG_H - ROW * CELL_H ))
    else
        WIN_H=$CELL_H
    fi

    echo "Window $i ($ADDR): pos=${WIN_X},${WIN_Y} size=${WIN_W}x${WIN_H}" >> /tmp/hypr-grid-debug.log
    hyprctl dispatch setfloating "address:$ADDR"
    hyprctl dispatch movewindowpixel "exact ${WIN_X} ${WIN_Y},address:$ADDR"
    hyprctl dispatch resizewindowpixel "exact ${WIN_W} ${WIN_H},address:$ADDR"
done

