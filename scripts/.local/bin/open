#!/bin/bash

# Usage: tmux-dev.sh [directory]
# Layout:
#   Left 25%:  Claude Code
#   Right 75%: nvim (top 2/3) + terminal (bottom 1/3)

DIR="${1:-.}"
DIR="$(realpath "$DIR")"
SESSION="dev"

if [ -n "$TMUX" ]; then
    echo "Already in tmux. Detach first."
    exit 1
fi

tmux kill-session -t "$SESSION" 2>/dev/null

# Start with nvim on the left
tmux new-session -d -s "$SESSION" -c "$DIR"
tmux send-keys -t "$SESSION" "nvim ." Enter

# Split below for terminal (bottom 1/3 of the left side)
tmux split-window -v -l 33% -t "$SESSION" -c "$DIR"

# Split right from nvim pane for Claude Code (25% width)
tmux split-window -h -l 25% -t "$SESSION:0.0" -c "$DIR"
tmux send-keys -t "$SESSION:0.2" "personal-claude" Enter

# Focus on nvim pane
tmux select-pane -t "$SESSION:0.0"
tmux attach-session -t "$SESSION"

