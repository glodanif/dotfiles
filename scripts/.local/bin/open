#!/bin/zsh
# Usage: tmux-dev.sh [directory]
# Layout:
#   Left 25%:  Claude Code
#   Right 75%: nvim (top 2/3) + terminal (bottom 1/3)

DIR="${1:-.}"
DIR="$(realpath "$DIR")"
SESSION="dev"

if [ -n "$TMUX" ]; then
    echo "Already in tmux. Detach first."
    exit 1
fi

tmux kill-session -t "$SESSION" 2>/dev/null

# Start with the left side
tmux new-session -d -s "$SESSION" -c "$DIR"
tmux send-keys -t "$SESSION" "nvim ." Enter

# Split right for Claude Code (25% width, full height)
tmux split-window -h -l 15% -t "$SESSION" -c "$DIR"
tmux send-keys -t "$SESSION" "personal-claude" Enter

# Go back to the left pane and split it for terminal (bottom 1/3)
tmux select-pane -t "$SESSION:0.0"
tmux split-window -v -l 25% -t "$SESSION" -c "$DIR"

# Focus on nvim pane
tmux select-pane -t "$SESSION:0.0"
tmux attach-session -t "$SESSION"

