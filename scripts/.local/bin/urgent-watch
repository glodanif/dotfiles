#!/bin/zsh

last_sound=0

play_sound() {
  local now=$(date +%s%3N)
  if (( now - last_sound >= 500 )); then
    last_sound=$now
    pw-play /usr/share/sounds/freedesktop/stereo/dialog-information.oga &
  fi
}

handle() {
  case $1 in
    'urgent>>'*)
      local addr="0x${1#urgent>>}"
      local window_workspace=$(hyprctl clients -j | jq -r ".[] | select(.address == \"$addr\") | .workspace.id")
      local active_workspace=$(hyprctl activeworkspace -j | jq -r ".id")
      if [[ -n "$window_workspace" && "$window_workspace" != "$active_workspace" ]]; then
        play_sound
      fi
      ;;
    'workspace>>'*)
      local ws_name="${1#workspace>>}"
      local has_urgent=$(hyprctl clients -j | jq -r ".[] | select(.workspace.name == \"$ws_name\" and .urgent == true) | .address" | head -1)
      if [[ -n "$has_urgent" ]]; then
        play_sound
      fi
      ;;
  esac
}

socat - "UNIX-CONNECT:$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock" | while read -r line; do
  handle "$line"
done
