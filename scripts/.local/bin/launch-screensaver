#!/bin/zsh
STATE_FILE="/tmp/screensaver-state"

pgrep -f screensaver/main.py && exit 0

jq -n \
  --argjson rounding "$(hyprctl getoption decoration:rounding -j | jq '.int')" \
  --argjson border_size "$(hyprctl getoption general:border_size -j | jq '.int')" \
  --arg window "$(hyprctl activewindow -j | jq -r '.address // ""')" \
  --arg monitor "$(hyprctl monitors -j | jq -r '.[] | select(.focused) | .name')" \
  '{rounding: $rounding, border_size: $border_size, window: $window, monitor: $monitor}' \
  > "$STATE_FILE"

restore() {
    exit-screensaver
}
trap restore SIGINT SIGTERM SIGHUP SIGQUIT

makoctl mode -a do-not-disturb &>/dev/null
#hyprctl keyword animations:enabled false &>/dev/null
#hyprctl keyword decoration:rounding 0 &>/dev/null
#hyprctl keyword general:border_size 0 &>/dev/null
#hyprctl keyword decoration:blur:enabled false &>/dev/null
#hyprctl keyword decoration:shadow:enabled false &>/dev/null
#hyprctl keyword cursor:invisible true &>/dev/null

for mon in $(hyprctl monitors -j | jq -r '.[].name'); do
    hyprctl dispatch focusmonitor "$mon"
    DISPLAY=":0" python "$HOME/.local/share/screensaver/main.py" &
done

while pgrep -f screensaver/main.py > /dev/null; do
    sleep 1
done
exit-screensaver

