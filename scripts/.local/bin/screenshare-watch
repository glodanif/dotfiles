#!/bin/zsh

LAST_STATE=""

check_sharing() {
    [[ -f /tmp/ongoing-screenrecording ]] && echo "off" && return
    pw-dump 2>/dev/null | jq -e '.[] | select(.info.props["media.class"] == "Video/Source" and .info.state == "running")' > /dev/null 2>&1 && echo "on" || echo "off"
}

print_status() {
    local state=$(check_sharing)
    [[ "$state" == "$LAST_STATE" ]] && return
    LAST_STATE="$state"
    if [[ "$state" == "on" ]]; then
        echo '{"text":" Screensharing ","class":"active","tooltip":"Screen is being shared"}'
    else
        echo '{"text":"","class":"idle","tooltip":""}'
    fi
}

print_status

LAST_EVENT=0
pactl subscribe | while read -r line; do
    case "$line" in
        *"on client #"*|*"on source-output #"*)
            NOW=$(date +%s)
            (( NOW - LAST_EVENT < 2 )) && continue
            LAST_EVENT=$NOW
            for i in 1 2 3 4; do
                print_status
                [[ "$LAST_STATE" == "on" ]] && break
                sleep 0.5
            done
            ;;
    esac
done
