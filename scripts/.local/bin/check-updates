#!/bin/zsh

cache_file="/tmp/waybar-updates-cache"
official=$(checkupdates 2>/dev/null | wc -l)
aur=$(yay -Qua 2>/dev/null | wc -l)
count=$(( official + aur ))

if (( count > 0 )); then
    printf '{"text":"%s","tooltip":"Official: %s\\nAUR: %s"}\n' "$count" "$official" "$aur" > "$cache_file"
else
    printf '' > "$cache_file"
fi

pkill -SIGRTMIN+8 waybar

