#!/bin/zsh
# Screen recording script
# Saves to ~/Videos/Recordings by default, override with XDG_VIDEOS_DIR env
[[ -f ~/.config/user-dirs.dirs ]] && source ~/.config/user-dirs.dirs
OUTPUT_DIR="${XDG_VIDEOS_DIR:-$HOME/Videos/Recordings}"
RECORDING_FILE="/tmp/screenrecord-filename"
PID_FILE="/tmp/screenrecord-pid"
RESOLUTION=""
CAPTURE_AUDIO=false
for arg in "$@"; do
  case "$arg" in
  --resolution=*) RESOLUTION="${arg#*=}" ;;
  --audio|--audio=true|--audio=1) CAPTURE_AUDIO=true ;;
  esac
done
default_resolution() {
  local width height
  read -r width height < <(hyprctl monitors -j | jq -r '.[] | select(.focused == true) | "\(.width) \(.height)"')
  if ((width > 3840 || height > 2160)); then
    echo "3840x2160"
  else
    echo "0x0"
  fi
}
signal_waybar() {
  for pid in $(pgrep waybar); do
    kill -$((34+8)) "$pid" 2>/dev/null
  done
  sleep 0.1
  for pid in $(pgrep waybar); do
    kill -$((34+8)) "$pid" 2>/dev/null
  done
}
start_recording() {
  if [[ -f "$RECORDING_FILE" ]]; then
    notify-send "Screen recording" "Already recording." -u normal -t 3000
    exit 1
  fi
  if [[ ! -d $OUTPUT_DIR ]]; then
    notify-send "Screen recording" "Output directory does not exist: $OUTPUT_DIR" -u critical -t 3000
    exit 1
  fi
  local filename="$OUTPUT_DIR/screenrecording-$(date +'%Y-%m-%d_%H-%M-%S').mp4"
  local resolution="${RESOLUTION:-$(default_resolution)}"
  local audio_args=""
  if [[ "$CAPTURE_AUDIO" == true ]]; then
    audio_args="-a default_output"
  fi
  nohup gpu-screen-recorder -w portal -k auto -s "$resolution" -f 60 -fm cfr -fallback-cpu-encoding yes $audio_args -o "$filename" &>/dev/null &
  local pid=$!
  disown
  # Wait for portal selection and recording to start
  while kill -0 $pid 2>/dev/null && [[ ! -f $filename ]]; do
    sleep 0.2
  done
  notify-send -t 1000 "Recording screen"
  if kill -0 $pid 2>/dev/null; then
    echo "$filename" > "$RECORDING_FILE"
    echo "$pid" > "$PID_FILE"
    signal_waybar
    exit 0
  fi
}
stop_recording() {
  local pid
  pid=$(cat "$PID_FILE" 2>/dev/null)
  
  if [[ -z "$pid" ]] || ! kill -0 "$pid" 2>/dev/null; then
    notify-send "Screen recording" "Not currently recording." -u normal -t 3000
    rm -f "$RECORDING_FILE" "$PID_FILE"
    exit 1
  fi

  kill -SIGINT "$pid"
  local count=0
  while kill -0 "$pid" 2>/dev/null && ((count < 50)); do
    sleep 0.1
    count=$((count + 1))
  done
  
  if kill -0 "$pid" 2>/dev/null; then
    kill -9 "$pid"
    rm -f "$RECORDING_FILE" "$PID_FILE"
    signal_waybar
    notify-send "Screen recording" "Force-killed. Video may be corrupted." -u critical -t 5000
    exit 1
  fi
  
  local filename
  filename=$(cat "$RECORDING_FILE" 2>/dev/null)
  rm -f "$RECORDING_FILE" "$PID_FILE"
  signal_waybar
  
  sleep 0.3
  
  if [[ -f "$filename" ]]; then
    local preview="${filename%.mp4}-preview.png"
    local tmpscript
    tmpscript=$(mktemp /tmp/screenrecord-notify-XXXX.sh)
    cat > "$tmpscript" << 'SCRIPT'
#!/bin/bash
ffmpeg -y -i "$FILENAME" -ss 00:00:01 -vframes 1 -q:v 2 "$PREVIEW" -loglevel quiet 2>/dev/null
ACTION=$(notify-send "Screen recording saved" "Click to open" -t 10000 -i "$PREVIEW" -A "default=Open")
[[ "$ACTION" == "default" ]] && mpv "$FILENAME"
rm -f "$PREVIEW" "$0"
SCRIPT
    chmod +x "$tmpscript"
    nohup env \
      PREVIEW="$preview" \
      FILENAME="$filename" \
      DBUS_SESSION_BUS_ADDRESS="$DBUS_SESSION_BUS_ADDRESS" \
      WAYLAND_DISPLAY="$WAYLAND_DISPLAY" \
      XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR" \
      "$tmpscript" &>/dev/null &
    disown
  fi
  exit 0
}
case "$1" in
  on)  start_recording ;;
  off) stop_recording ;;
  *)
    echo "Usage: screenrecord on|off [--audio] [--resolution=WxH]"
    exit 1
    ;;
esac

